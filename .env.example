# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Comma-separated channel IDs to watch
DISCORD_WATCH_CHANNEL_IDS=

# Hacker Portal ingestion endpoint
PORTAL_API_URL=

# Shared bearer secret expected by portal API, set to anything [that is secure]
# Set env variable DISCORD_INGEST_SECRET in Portal repo to match
PORTAL_API_SECRET=

# Optional request timeout in ms
PORTAL_API_TIMEOUT_MS=10000

# Retry configuration
PORTAL_MAX_RETRIES=5
PORTAL_RETRY_BASE_DELAY_MS=500
PORTAL_RETRY_MAX_DELAY_MS=10000

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
